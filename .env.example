# stress-tester local defaults
#
# Copy to .env and customize. This file is intentionally compatible with the
# environment variables used by docker-compose.yml and docker-compose.appgarden.yml.

KAMIWAZA_URL=https://host.docker.internal
KAMIWAZA_ADMIN_USER=admin
# KAMIWAZA_ADMIN_PASSWORD=
# KAMIWAZA_ADMIN_TOKEN=

# Anthropic key enables vision features (optional)
# ANTHROPIC_API_KEY=

# Host/listen ports
STRESS_TESTER_PORT=18090
STRESS_TESTER_HOST_PORT=18090

# Where to scan for extension repos to load .uat/ guidance from (optional)
# STRESS_TESTER_EXTENSION_ROOTS=/workspace/k8s/kamiwaza-extensions-*

# Docker image prefix for make build/push
IMAGE_PREFIX=kamiwazaai

